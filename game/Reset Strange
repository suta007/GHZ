-- 1. สร้าง Tab สำหรับดู Log โดยเฉพาะ (หรือเอาไปใส่ใน Tab เดิมที่มีอยู่ก็ได้ค่ะ)
local LogTab = Window:AddTab({ Title = "System Logs", Icon = "scroll" })

-- 2. สร้าง Paragraph เพื่อใช้เป็นหน้าจอแสดงผล
local LogDisplay = LogTab:AddParagraph({
    Title = "EfHub Activity Logs",
    Content = "Waiting for system to start...\n"
})

-- 3. ตัวแปรเก็บประวัติข้อความ
local logHistory = ""
local logCount = 0

-- 4. ฟังก์ชันสำหรับเพิ่ม Log เข้าไปในหน้าจอ
local function AddLog(message)
    -- ดึงเวลาปัจจุบันมาใส่หน้าข้อความ
    local timeString = os.date("%H:%M:%S") 
    local newLog = "[" .. timeString .. "] " .. message .. "\n"
    
    -- เอาข้อความใหม่ไปต่อท้ายข้อความเก่า
    logHistory = newLog .. logHistory 
    logCount = logCount + 1
    
    -- (Option) ป้องกันไม่ให้ Log ยาวเกินไปจน UI ค้าง (จำกัดไว้ที่ 50 บรรทัด)
    if logCount > 50 then
        -- ตัดบรรทัดสุดท้ายทิ้ง (ลอจิกง่ายๆ คือตัด string)
        logHistory = string.sub(logHistory, 1, string.find(logHistory, "\n", -2))
        logCount = 50
    end
    
    -- อัปเดตข้อความบน UI
    LogDisplay:SetDesc(logHistory)
end

-- วิธีเรียกใช้งาน
AddLog("🚀 เริ่มระบบ Auto IGMA")
task.wait(2)
AddLog("✅ ทำการดึงข้อมูลจาก Server สำเร็จ (แต้ม: 15/50)")
task.wait(2)
AddLog("💰 รีเซ็ตเควสสำเร็จ หักเงิน 100M Shillings")